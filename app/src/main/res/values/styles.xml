<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="EditBox">
        <item name="android:importantForAutofill">no</item>
        <item name="android:background">@drawable/input_focused</item>
        <item name="android:textCursorDrawable">@drawable/cursor</item>
        <item name="android:lineSpacingExtra">4dp</item>
    </style>

    <style name="Button">
        <item name="android:paddingHorizontal">12dp</item>
        <item name="android:paddingVertical">12dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:minHeight">0dp</item>
        <item name="android:minWidth">0dp</item>
    </style>

    <style name="Chip.Choice.Range" parent="Widget.MaterialComponents.Chip.Filter">
        <item name="ensureMinTouchTargetSize">false</item>
        <item name="chipStrokeWidth">2dp</item>
        <item name="chipCornerRadius">12dp</item>
        <item name="chipMinHeight">0dp</item>
        <item name="chipStartPadding">0dp</item>
        <item name="chipEndPadding">0dp</item>
        <item name="textStartPadding">0dp</item>
        <item name="textEndPadding">0dp</item>
        <item name="checkedIconVisible">false</item>
        <item name="chipBackgroundColor">@color/chip_choice_range_background</item>
        <item name="chipStrokeColor">@color/chip_choice_range_stroke</item>
        <item name="android:includeFontPadding">true</item>
        <item name="android:textAppearance">@style/Body_14_M</item>
        <item name="android:paddingVertical">11dp</item>
        <item name="android:textColor">@color/label_normal</item>
        <item name="android:textAlignment">center</item>
    </style>

    <style name="ThemeOverlay.App.BottomSheetDialog" parent="ThemeOverlay.Material3.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/Widget.App.BottomSheet</item>
        <!-- 다이얼로그 배경을 투명하게 설정 -->
        <item name="android:windowIsFloating">false</item>
        <item name="android:windowSoftInputMode">adjustResize</item>
        <item name="android:backgroundDimEnabled">true</item>
        <item name="android:backgroundDimAmount">0.5</item>
        <item name="android:windowBackground">@android:color/transparent</item>
    </style>

    <style name="Widget.App.BottomSheet" parent="Widget.Material3.BottomSheet">
        <item name="shapeAppearance">@style/ShapeAppearance.App.LargeComponent</item>
        <item name="backgroundTint">@color/background_normal</item>
    </style>

    <style name="ShapeAppearance.App.LargeComponent" parent="ShapeAppearance.Material3.LargeComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">28dp</item>
    </style>

    <style name="Body_10_M">
