<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape>
            <solid android:color="@color/fill_alternative" />  <!-- 반투명한 검은색 배경 -->
            <corners android:radius="100dp" />
        </shape>
    </item>
    <item>
        <clip>
            <shape>
                <solid android:color="@color/primary" /> <!-- 진행 부분 색 -->
                <corners android:radius="100dp" />
            </shape>
        </clip>
    </item>
</layer-list>