<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        xmlns:tools="http://schemas.android.com/tools">

    <data>

        <variable name="vm" type="com.tenacy.roadcapture.ui.AppInfoViewModel"/>
        <import type="android.view.View"/>
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout android:id="@+id/cl_app_info_container"
                                                       android:layout_width="match_parent"
                                                       android:layout_height="match_parent"
                                                       android:background="@color/background_normal">

        <ScrollView android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:clipToPadding="false"
                    android:paddingVertical="40dp"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent">

            <LinearLayout android:layout_width="match_parent"
                          android:layout_height="wrap_content"
                          android:orientation="vertical">

                <TextView android:layout_width="wrap_content"
                          android:layout_height="wrap_content"
                          android:textAppearance="@style/Body_12_M"
                          android:textColor="@color/label_normal"
                          android:text="앱"
                          android:layout_marginHorizontal="20dp"/>

                <LinearLayout android:layout_width="match_parent"
                              android:layout_height="wrap_content"
                              android:id="@+id/ll_app_info_app"
                              android:orientation="horizontal"
                              android:paddingVertical="12dp"
                              android:layout_marginTop="16dp"
                              android:gravity="center_vertical"
                              android:paddingHorizontal="20dp"
                              android:clickable="true"
                              android:focusable="true"
                              android:foreground="?attr/selectableItemBackground">

                    <com.google.android.material.card.MaterialCardView android:layout_width="36dp"
                                                                       android:layout_height="36dp"
                                                                       app:cardBackgroundColor="@color/background_normal"
                                                                       app:cardCornerRadius="14dp"
                                                                       app:cardElevation="0dp"
                                                                       app:strokeWidth="1dp"
                                                                       app:strokeColor="@color/fill_assistive">

                        <ImageView android:layout_width="21.6dp"
                                   android:layout_height="17.74dp"
                                   android:src="@drawable/ic_logo"
                                   android:layout_gravity="center"/>

                    </com.google.android.material.card.MaterialCardView>

                    <TextView android:layout_width="0dp"
                              android:layout_height="wrap_content"
                              android:layout_weight="1"
                              android:textAppearance="@style/Body_14_M"
                              android:textColor="@color/label_normal"
                              android:text="로드캡처"
                              android:layout_marginHorizontal="10dp"/>

                    <TextView android:layout_width="wrap_content"
                              android:layout_height="wrap_content"
                              android:textAppearance="@style/Body_12_M"
                              android:textColor="@color/label_assistive"
                              android:text="@{vm.version}"
                              tools:text="0.1.0"/>

                </LinearLayout>

                <View android:layout_width="match_parent"
                      android:layout_height="0.5dp"
                      android:background="@color/line_neutral"
                      android:layout_marginHorizontal="20dp"/>

                <LinearLayout android:layout_width="match_parent"
                              android:layout_height="wrap_content"
                              android:orientation="horizontal"
                              android:paddingVertical="20dp"
                              android:gravity="center_vertical"
                              android:paddingHorizontal="20dp"
                              android:clickable="true"
                              android:focusable="true"
                              android:foreground="?attr/selectableItemBackground">

                    <TextView android:layout_width="0dp"
                              android:layout_height="wrap_content"
                              android:layout_weight="1"
                              android:textAppearance="@style/Body_14_M"
                              android:textColor="@color/label_normal"
                              android:text="최근 업데이트"/>

                    <TextView android:layout_width="wrap_content"
                              android:layout_height="wrap_content"
                              android:textAppearance="@style/Body_12_M"
                              android:textColor="@color/label_assistive"
                              android:text="2025-05-07"/>

                </LinearLayout>

                <View android:layout_width="match_parent"
                      android:layout_height="0.5dp"
                      android:background="@color/line_neutral"
                      android:layout_marginHorizontal="20dp"/>

                <LinearLayout android:layout_width="match_parent"
                              android:layout_height="wrap_content"
                              app:safeClick="@{() -> vm.onAppReviewClick()}"
                              android:orientation="horizontal"
                              android:paddingVertical="20dp"
                              android:gravity="center_vertical"
                              android:paddingHorizontal="20dp"
                              android:clickable="true"
                              android:focusable="true"
                              android:foreground="?attr/selectableItemBackground">

                    <TextView android:layout_width="0dp"
                              android:layout_height="wrap_content"
                              android:layout_weight="1"
                              android:textAppearance="@style/Body_14_M"
                              android:textColor="@color/label_normal"
                              android:text="앱 평가하기"/>

                </LinearLayout>

                <View android:layout_width="match_parent"
                      android:layout_height="0.5dp"
                      android:background="@color/line_neutral"
                      android:layout_marginHorizontal="20dp"/>

                <LinearLayout android:layout_width="match_parent"
                              android:layout_height="wrap_content"
                              android:orientation="horizontal"
                              app:safeClick="@{() -> vm.onDonateClick()}"
                              android:paddingVertical="20dp"
                              android:gravity="center_vertical"
                              android:paddingHorizontal="20dp"
                              android:clickable="true"
                              android:focusable="true"
                              android:foreground="?attr/selectableItemBackground">

                    <TextView android:layout_width="0dp"
                              android:layout_height="wrap_content"
                              android:layout_weight="1"
                              android:textAppearance="@style/Body_14_M"
                              android:textColor="@color/label_normal"
                              android:text="개발자에게 후원하기"/>

                </LinearLayout>

                <View android:layout_width="match_parent"
                      android:layout_height="1dp"
                      android:background="@color/line_normal"
                      android:layout_marginVertical="24dp"/>

                <TextView android:layout_width="wrap_content"
                          android:layout_height="wrap_content"
                          android:textAppearance="@style/Body_12_M"
                          android:textColor="@color/label_normal"
                          android:text="사용자 지원"
                          android:layout_marginHorizontal="20dp"/>

                <LinearLayout android:layout_width="match_parent"
                              android:layout_height="wrap_content"
                              android:orientation="horizontal"
                              app:safeClick="@{() -> vm.onInquiryClick()}"
                              android:paddingVertical="20dp"
                              android:layout_marginTop="16dp"
                              android:gravity="center_vertical"
                              android:paddingHorizontal="20dp"
                              android:clickable="true"
                              android:focusable="true"
                              android:foreground="?attr/selectableItemBackground">

                    <TextView android:layout_width="0dp"
                              android:layout_height="wrap_content"
                              android:layout_weight="1"
                              android:textAppearance="@style/Body_14_M"
                              android:textColor="@color/label_normal"
                              android:text="개발자에게 문의하기"/>

                </LinearLayout>

                <View android:layout_width="match_parent"
                      android:layout_height="1dp"
                      android:background="@color/line_normal"
                      android:layout_marginVertical="24dp"/>

                <TextView android:layout_width="wrap_content"
                          android:layout_height="wrap_content"
                          android:textAppearance="@style/Body_12_M"
                          android:textColor="@color/label_normal"
                          android:text="약관 및 정책"
                          android:layout_marginHorizontal="20dp"/>

                <LinearLayout android:layout_width="match_parent"
                              android:layout_height="wrap_content"
                              android:orientation="horizontal"
                              app:safeClick="@{() -> vm.onServiceTermsAndConditionsClick()}"
                              android:paddingVertical="20dp"
                              android:layout_marginTop="16dp"
                              android:gravity="center_vertical"
                              android:paddingHorizontal="20dp"
                              android:clickable="true"
                              android:focusable="true"
                              android:foreground="?attr/selectableItemBackground">

                    <TextView android:layout_width="0dp"
                              android:layout_height="wrap_content"
                              android:layout_weight="1"
                              android:textAppearance="@style/Body_14_M"
                              android:textColor="@color/label_normal"
                              android:text="서비스 이용약관"/>

                </LinearLayout>

                <View android:layout_width="match_parent"
                      android:layout_height="0.5dp"
                      android:background="@color/line_neutral"
                      android:layout_marginHorizontal="20dp"/>

                <LinearLayout android:layout_width="match_parent"
                              android:layout_height="wrap_content"
                              android:orientation="horizontal"
                              app:safeClick="@{() -> vm.onPersonalInfoPolicyClick()}"
                              android:paddingVertical="20dp"
                              android:gravity="center_vertical"
                              android:paddingHorizontal="20dp"
                              android:clickable="true"
                              android:focusable="true"
                              android:foreground="?attr/selectableItemBackground">

                    <TextView android:layout_width="0dp"
                              android:layout_height="wrap_content"
                              android:layout_weight="1"
                              android:textAppearance="@style/Body_14_M"
                              android:textColor="@color/label_normal"
                              android:text="개인정보 처리방침"/>

                </LinearLayout>

                <View android:layout_width="match_parent"
                      android:layout_height="1dp"
                      android:background="@color/line_normal"
                      android:layout_marginVertical="24dp"/>

                <TextView android:layout_width="wrap_content"
                          android:layout_height="wrap_content"
                          android:textAppearance="@style/Body_12_M"
                          android:textColor="@color/label_normal"
                          android:text="계정 관리"
                          android:layout_marginHorizontal="20dp"/>

                <LinearLayout android:layout_width="match_parent"
                              android:layout_height="wrap_content"
                              android:orientation="horizontal"
                              android:paddingVertical="12dp"
                              android:layout_marginTop="16dp"
                              android:gravity="center_vertical"
                              android:paddingHorizontal="20dp"
                              android:clickable="true"
                              android:focusable="true"
                              android:foreground="?attr/selectableItemBackground">

                    <ImageView android:layout_width="36dp"
                               android:layout_height="36dp"
                               app:radius="@{100}"
                               app:uri="@{vm.profilePhotoUrl}"/>

                    <TextView android:layout_width="0dp"
                              android:layout_height="wrap_content"
                              android:layout_weight="1"
                              android:textAppearance="@style/Body_14_M"
                              android:textColor="@color/label_normal"
                              android:text="@{vm.profileDisplayName}"
                              tools:text="이원석"
                              android:layout_marginHorizontal="10dp"/>

                    <ImageView android:layout_width="24dp"
                               android:layout_height="24dp"
                               app:src="@{vm.providerDrawable}"
                               tools:src="@drawable/ic_google"/>

                </LinearLayout>

                <View android:layout_width="match_parent"
                      android:layout_height="0.5dp"
                      android:background="@color/line_neutral"
                      android:layout_marginHorizontal="20dp"/>

                <LinearLayout android:layout_width="match_parent"
                              android:layout_height="wrap_content"
                              app:safeClick="@{() -> vm.onSubscribeClick()}"
                              app:debounceTime="@{2000L}"
                              android:orientation="horizontal"
                              android:paddingVertical="20dp"
                              android:gravity="center_vertical"
                              android:paddingHorizontal="20dp"
                              android:clickable="true"
                              android:focusable="true"
                              android:foreground="?attr/selectableItemBackground">

                    <TextView android:layout_width="0dp"
                              android:layout_height="wrap_content"
                              android:layout_weight="1"
                              android:textAppearance="@style/Body_14_M"
                              android:textColor="@color/label_normal"
                              android:text="@{vm.isSubscriptionActive ? `정기구독 관리` : `정기구독하기`}"
                              tools:text="정기구독하기"/>

                    <LinearLayout android:layout_width="wrap_content"
                                  android:layout_height="wrap_content"
                                  android:orientation="horizontal"
                                  android:gravity="center_vertical">

                        <ImageView android:layout_width="14dp"
                                   android:layout_height="14dp"
                                   android:src="@drawable/ic_crown_active"
                                   android:visibility="@{vm.isSubscriptionActive ? View.VISIBLE : View.GONE}"
                                   tools:visibility="visible"
                                   android:layout_marginEnd="4dp"/>

                        <TextView android:layout_width="wrap_content"
                                  android:layout_height="wrap_content"
                                  android:textAppearance="@style/Body_12_M"
                                  android:textColor="@{vm.isSubscriptionActive ? @color/special : @color/label_assistive}"
                                  tools:textColor="@color/special"
                                  android:textAlignment="textEnd"
                                  android:text="@{vm.subscriptionText}"
                                  tools:text="프리미엄 구독중"/>

                    </LinearLayout>

                </LinearLayout>

                <View android:layout_width="match_parent"
                      android:layout_height="0.5dp"
                      android:background="@color/line_neutral"
                      android:layout_marginHorizontal="20dp"/>

                <LinearLayout android:layout_width="match_parent"
                              android:layout_height="wrap_content"
                              android:orientation="horizontal"
                              app:safeClick="@{() -> vm.onLogoutClick()}"
                              android:paddingVertical="20dp"
                              android:gravity="center_vertical"
                              android:paddingHorizontal="20dp"
                              android:clickable="true"
                              android:focusable="true"
                              android:foreground="?attr/selectableItemBackground">

                    <TextView android:layout_width="0dp"
                              android:layout_height="wrap_content"
                              android:layout_weight="1"
                              android:textAppearance="@style/Body_14_M"
                              android:textColor="@color/label_normal"
                              android:text="로그아웃"/>

                </LinearLayout>

                <View android:layout_width="match_parent"
                      android:layout_height="0.5dp"
                      android:background="@color/line_neutral"
                      android:layout_marginHorizontal="20dp"/>

                <LinearLayout android:layout_width="match_parent"
                              android:layout_height="wrap_content"
                              app:safeClick="@{() -> vm.onWithdrawClick()}"
                              android:orientation="horizontal"
                              android:paddingVertical="20dp"
                              android:gravity="center_vertical"
                              android:paddingHorizontal="20dp"
                              android:clickable="true"
                              android:focusable="true"
                              android:foreground="?attr/selectableItemBackground">

                    <TextView android:layout_width="0dp"
                              android:layout_height="wrap_content"
                              android:layout_weight="1"
                              android:textAppearance="@style/Body_14_M"
                              android:textColor="@color/label_normal"
                              android:text="서비스 탈퇴"/>

                </LinearLayout>

            </LinearLayout>

        </ScrollView>

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>
