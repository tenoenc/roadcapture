<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        xmlns:tools="http://schemas.android.com/tools">

    <data>

        <variable name="selected" type="Boolean"/>
        <variable name="value" type="String"/>
        <variable name="text" type="String"/>
        <variable name="flag" type="String"/>
    </data>

    <com.google.android.material.card.MaterialCardView android:layout_width="match_parent"
                                                       android:layout_height="wrap_content"
                                                       app:selected="@{selected}"
                                                       app:rippleColor="@android:color/transparent"
                                                       app:cardBackgroundColor="@color/chip_choice_range_background"
                                                       app:cardElevation="0dp"
                                                       app:cardCornerRadius="12dp"
                                                       app:strokeColor="@color/chip_choice_range_stroke"
                                                       app:strokeWidth="2dp">
        <LinearLayout android:layout_width="match_parent"
                      android:layout_height="wrap_content"
                      android:orientation="horizontal"
                      android:padding="12dp">

            <LinearLayout android:layout_width="0dp"
                          android:layout_height="wrap_content"
                          android:layout_weight="1"
                          android:orientation="vertical">

                <TextView android:layout_width="match_parent"
                          android:layout_height="wrap_content"
                          android:textAppearance="@style/Body_14_M"
                          android:textColor="@color/label_normal"
                          android:text="@{value}"
                          tools:text="한국 표준시"/>

                <TextView android:layout_width="match_parent"
                          android:layout_height="wrap_content"
                          android:textAppearance="@style/Body_12_M"
                          android:textColor="@color/label_neutral"
                          android:text="@{text}"
                          tools:text="(UTC+09:00) Seoul"/>

            </LinearLayout>

            <TextView android:layout_width="wrap_content"
                      android:layout_height="wrap_content"
                      android:layout_gravity="center_vertical"
                      android:layout_marginStart="4dp"
                      android:textAppearance="@style/Title_24"
                      android:textColor="@color/label_normal"
                      android:text="@{flag}"
                      tools:text="🇰🇷" />

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

</layout>
