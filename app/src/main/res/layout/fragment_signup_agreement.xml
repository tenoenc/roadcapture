<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
>

    <data>

        <variable name="vm" type="com.tenacy.roadcapture.ui.SignupAgreementViewModel"/>

        <import type="android.view.View"/>
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/background_normal">

        <LinearLayout android:layout_width="0dp"
                      android:layout_height="wrap_content"
                      android:id="@+id/ll_signup_agreement_a_bar_container"
                      android:orientation="horizontal"
                      android:paddingHorizontal="16dp"
                      android:paddingVertical="8dp"
                      app:layout_constraintStart_toStartOf="parent"
                      app:layout_constraintTop_toTopOf="parent"
                      app:layout_constraintEnd_toEndOf="parent">

            <ImageButton
                    android:id="@+id/ibtn_a_bar_back"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/ic_arrow_left"
                    android:background="@null"
                    android:scaleType="fitCenter"/>

        </LinearLayout>

        <TextView android:layout_width="0dp"
                  android:layout_height="wrap_content"
                  android:id="@+id/txt_signup_agreement_title"
                  android:layout_marginTop="80dp"
                  android:layout_marginHorizontal="20dp"
                  android:textAppearance="@style/Title_20"
                  android:textColor="@color/label_normal"
                  android:textAlignment="textStart"
                  android:text="서비스 가입"
                  app:layout_constraintTop_toBottomOf="@id/ll_signup_agreement_a_bar_container"
                  app:layout_constraintStart_toStartOf="parent"
                  app:layout_constraintEnd_toEndOf="parent"/>

        <com.google.android.material.card.MaterialCardView android:layout_width="0dp"
                                                           android:layout_height="wrap_content"
                                                           android:id="@+id/card_signup_agreement_all"
                                                           app:selected="@{vm.allChecked}"
                                                           android:onClick="@{() -> vm.onAgreeAllClick()}"
                                                           app:layout_constraintTop_toBottomOf="@id/txt_signup_agreement_title"
                                                           app:layout_constraintStart_toStartOf="parent"
                                                           app:layout_constraintEnd_toEndOf="parent"
                                                           app:rippleColor="@android:color/transparent"
                                                           android:layout_marginHorizontal="20dp"
                                                           android:layout_marginTop="28dp"
                                                           app:strokeWidth="1dp"
                                                           app:strokeColor="@color/chip_choice_agreement_stroke"
                                                           app:cardBackgroundColor="@color/background_alternative"
                                                           app:cardElevation="0dp"
                                                           app:cardCornerRadius="12dp">

            <LinearLayout android:layout_width="match_parent"
                          android:layout_height="wrap_content"
                          android:orientation="horizontal"
                          android:gravity="center"
                          android:padding="16dp">

                <ImageView android:layout_width="24dp"
                             android:layout_height="24dp"
                             android:src="@drawable/checkbox"/>

                <TextView android:layout_width="0dp"
                          android:layout_height="wrap_content"
                          android:layout_weight="1"
                          android:textAppearance="@style/Body_14_M"
                          android:textColor="@color/label_normal"
                          android:text="약관 전체 동의"
                          android:layout_marginStart="6dp" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView android:layout_width="0dp"
                                                           android:layout_height="wrap_content"
                                                           android:id="@+id/card_signup_agreement_1"
                                                           android:onClick="@{() -> vm.onAgreeTermsOfServiceClick()}"
                                                           app:selected="@{vm.agreeTermsOfService}"
                                                           app:layout_constraintTop_toBottomOf="@id/card_signup_agreement_all"
                                                           app:layout_constraintStart_toStartOf="parent"
                                                           app:layout_constraintEnd_toEndOf="parent"
                                                           app:rippleColor="@android:color/transparent"
                                                           android:layout_marginHorizontal="20dp"
                                                           android:layout_marginTop="12dp"
                                                           app:strokeWidth="0dp"
                                                           app:cardBackgroundColor="@color/background_alternative"
                                                           app:cardElevation="0dp"
                                                           app:cardCornerRadius="12dp">

            <LinearLayout android:layout_width="match_parent"
                          android:layout_height="wrap_content"
                          android:orientation="horizontal"
                          android:gravity="center"
                          android:paddingStart="16dp">

                <ImageView android:layout_width="24dp"
                             android:layout_height="24dp"
                             android:src="@drawable/checkbox"/>

                <TextView android:layout_width="0dp"
                          android:layout_height="wrap_content"
                          android:layout_weight="1"
                          android:textAppearance="@style/Body_14_M"
                          android:textColor="@color/label_normal"
                          android:text="서비스 이용약관 필수동의"
                          android:layout_marginHorizontal="6dp" />

                <ImageButton android:layout_width="56dp"
                             android:layout_height="56dp"
                             app:safeClick="@{() -> vm.onAgreeTermsOfServiceDetailClick()}"
                             android:padding="16dp"
                             android:src="@drawable/ic_simple_arrow_right"
                             app:tint="@color/line_normal"
                             android:background="@null"
                             android:scaleType="fitCenter"/>

            </LinearLayout>


        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView android:layout_width="0dp"
                                                           android:layout_height="wrap_content"
                                                           android:id="@+id/card_signup_agreement_2"
                                                           android:onClick="@{() -> vm.onAgreePrivacyPolicyClick()}"
                                                           app:selected="@{vm.agreePrivacyPolicy}"
                                                           app:layout_constraintTop_toBottomOf="@id/card_signup_agreement_1"
                                                           app:layout_constraintStart_toStartOf="parent"
                                                           app:layout_constraintEnd_toEndOf="parent"
                                                           app:rippleColor="@android:color/transparent"
                                                           android:layout_marginHorizontal="20dp"
                                                           android:layout_marginTop="12dp"
                                                           app:strokeWidth="0dp"
                                                           app:cardBackgroundColor="@color/background_alternative"
                                                           app:cardElevation="0dp"
                                                           app:cardCornerRadius="12dp">

            <LinearLayout android:layout_width="match_parent"
                          android:layout_height="wrap_content"
                          android:orientation="horizontal"
                          android:gravity="center"
                          android:paddingStart="16dp">

                <ImageView android:layout_width="24dp"
                             android:layout_height="24dp"
                             android:src="@drawable/checkbox"/>

                <TextView android:layout_width="0dp"
                          android:layout_height="wrap_content"
                          android:layout_weight="1"
                          android:textAppearance="@style/Body_14_M"
                          android:textColor="@color/label_normal"
                          android:text="개인정보 수집 · 이용 필수동의"
                          android:layout_marginHorizontal="6dp" />

                <ImageButton android:layout_width="56dp"
                             android:layout_height="56dp"
                             app:safeClick="@{() -> vm.onAgreePrivacyPolicyDetailClick()}"
                             android:padding="16dp"
                             android:src="@drawable/ic_simple_arrow_right"
                             app:tint="@color/line_normal"
                             android:background="@null"
                             android:scaleType="fitCenter"/>

            </LinearLayout>


        </com.google.android.material.card.MaterialCardView>


        <Button android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:id="@+id/btn_signup_agreement_start"
                app:safeClick="@{() -> vm.onStartClick()}"
                android:visibility="@{vm.allChecked ? View.VISIBLE : View.INVISIBLE}"
                style="@style/Button"
                android:textAppearance="@style/Body_16_SB"
                android:textColor="@color/label_normal"
                android:text="시작하기"
                android:backgroundTint="@color/primary_normal"
                app:cornerRadius="12dp"
                android:padding="12dp"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="20dp"
                android:layout_marginHorizontal="20dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

</layout>
