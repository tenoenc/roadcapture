<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        xmlns:tools="http://schemas.android.com/tools">

    <data>

        <variable name="toggleText" type="String"/>
    </data>

    <LinearLayout android:id="@+id/ll_b_sheet_my_album_more_container"
                  android:layout_width="match_parent"
                  android:layout_height="wrap_content"
                  android:orientation="vertical"
                  android:gravity="center"
                  app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior">

        <androidx.cardview.widget.CardView android:layout_width="48dp"
                                           android:layout_height="4dp"
                                           android:id="@+id/card_b_sheet_my_album_more_handle"
                                           app:cardElevation="0dp"
                                           app:cardCornerRadius="10dp"
                                           app:cardBackgroundColor="@color/fill_neutral"
                                           android:layout_marginTop="16dp"/>

        <com.google.android.material.button.MaterialButton android:layout_width="match_parent"
                                                           android:layout_height="wrap_content"
                                                           android:id="@+id/btn_b_sheet_my_album_more_modify"
                                                           style="@style/Button"
                                                           android:textAppearance="@style/Body_16_SB"
                                                           android:textColor="@color/label_normal"
                                                           android:text="@{toggleText}"
                                                           tools:text="비공개로 전환하기"
                                                           android:backgroundTint="@color/background_normal"
                                                           app:strokeWidth="1dp"
                                                           app:strokeColor="@color/line_normal"
                                                           app:cornerRadius="12dp"
                                                           android:padding="12dp"
                                                           android:layout_marginTop="20dp"
                                                           android:layout_marginHorizontal="20dp"/>

        <Button android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:id="@+id/btn_b_sheet_my_album_more_delete"
                style="@style/Button"
                android:textAppearance="@style/Body_16_SB"
                android:textColor="@color/background_normal"
                android:text="삭제하기"
                android:backgroundTint="@color/warning"
                app:cornerRadius="12dp"
                android:padding="12dp"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="20dp"
                android:layout_marginHorizontal="20dp"/>

    </LinearLayout>
</layout>
