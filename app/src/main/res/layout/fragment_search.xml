<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        xmlns:tools="http://schemas.android.com/tools">
    
    <data>
        
        <variable name="vm" type="com.tenacy.roadcapture.ui.SearchViewModel"/>
    </data>
    
    <androidx.constraintlayout.widget.ConstraintLayout android:id="@+id/cl_search_container"
                                                       android:layout_width="match_parent"
                                                       android:layout_height="match_parent"
                                                       android:background="@color/background_normal">

        <LinearLayout android:layout_width="0dp"
                      android:layout_height="wrap_content"
                      android:id="@+id/ll_search_a_bar_container"
                      android:paddingHorizontal="20dp"
                      android:paddingVertical="4dp"
                      android:orientation="horizontal"
                      android:gravity="center_vertical"
                      android:background="@color/background_normal"
                      app:layout_constraintTop_toTopOf="parent"
                      app:layout_constraintEnd_toEndOf="parent"
                      app:layout_constraintStart_toStartOf="parent">

            <ImageButton
                    android:id="@+id/ibtn_a_bar_back"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_arrow_left"
                    android:background="@null"
                    android:scaleType="fitCenter"/>

            <androidx.cardview.widget.CardView android:layout_width="0dp"
                                               android:layout_height="wrap_content"
                                               android:id="@+id/card_search_input"
                                               android:layout_weight="1"
                                               android:layout_marginStart="10dp"
                                               app:cardElevation="0dp"
                                               app:cardBackgroundColor="@color/fill_assistive"
                                               app:cardCornerRadius="100dp">

                <LinearLayout android:layout_width="match_parent"
                              android:layout_height="wrap_content"
                              android:orientation="horizontal"
                              android:gravity="center_vertical"
                              android:paddingStart="12dp"
                              android:paddingEnd="6dp"
                              android:paddingVertical="3dp">

                    <EditText android:layout_width="0dp"
                              android:layout_height="wrap_content"
                              android:layout_weight="1"
                              android:background="@null"
                              android:textCursorDrawable="@color/label_normal"
                              android:importantForAutofill="no"
                              android:inputType="text"
                              android:textAppearance="@style/Body_12_M"
                              android:textColor="@color/label_normal"
                              android:textAlignment="textStart"
                              android:hint="제목, 사용자, 지역, 장소"
                              android:textColorHint="@color/fill_neutral" />

                    <ImageButton android:layout_width="16dp"
                                 android:layout_height="16dp"
                                 android:src="@drawable/ic_x"
                                 android:background="@null"
                                 android:scaleType="fitCenter"
                                 android:layout_marginStart="4dp"/>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <com.google.android.material.card.MaterialCardView android:layout_width="wrap_content"
                                                               android:layout_height="wrap_content"
                                                               android:layout_marginStart="10dp"
                                                               app:cardBackgroundColor="@color/background_normal"
                                                               app:strokeWidth="1dp"
                                                               app:strokeColor="@color/label_normal"
                                                               app:cardCornerRadius="100dp"
                                                               app:cardElevation="0dp">

                <TextView android:layout_width="wrap_content"
                          android:layout_height="wrap_content"
                          android:paddingVertical="3dp"
                          android:paddingHorizontal="12dp"
                          android:textAppearance="@style/Body_12_M"
                          android:textColor="@color/label_normal"
                          tools:text="북마크 - 검색"/>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

        <View android:layout_width="0dp"
              android:layout_height="1dp"
              android:id="@+id/view_search_1"
              android:background="@color/line_normal"
              app:layout_constraintTop_toBottomOf="@id/ll_search_a_bar_container"
              app:layout_constraintStart_toStartOf="parent"
              app:layout_constraintEnd_toEndOf="parent"/>

        <androidx.recyclerview.widget.RecyclerView android:layout_width="0dp"
                                                   android:layout_height="0dp"
                                                   android:clipToPadding="false"
                                                   android:paddingBottom="20dp"
                                                   tools:listitem="@layout/item_album"
                                                   app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                                                   app:layout_constraintTop_toBottomOf="@id/view_search_1"
                                                   app:layout_constraintBottom_toBottomOf="parent"
                                                   app:layout_constraintStart_toStartOf="parent"
                                                   app:layout_constraintEnd_toEndOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>
