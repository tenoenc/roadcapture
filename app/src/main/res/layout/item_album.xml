<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        xmlns:tools="http://schemas.android.com/tools">

    <data>

        <variable name="thumbnailUrl" type="String"/>
        <variable name="profileImageUrl" type="String"/>
        <variable name="username" type="String"/>
        <variable name="numericalText" type="String"/>
        <variable name="title" type="String"/>
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout android:id="@+id/cl_i_album_container"
                                                       android:layout_width="match_parent"
                                                       android:layout_height="wrap_content">

        <ImageView android:layout_width="0dp"
                   android:layout_height="0dp"
                   android:id="@+id/img_i_album_thumbnail"
                   app:url="@{thumbnailUrl}"
                   app:layout_constraintDimensionRatio="16:9"
                   app:layout_constraintStart_toStartOf="parent"
                   app:layout_constraintEnd_toEndOf="parent"
                   app:layout_constraintTop_toTopOf="parent"/>

        <LinearLayout android:layout_width="0dp"
                      android:layout_height="wrap_content"
                      android:id="@+id/ll_i_album_row_1"
                      android:orientation="horizontal"
                      android:paddingHorizontal="20dp"
                      android:layout_marginTop="10dp"
                      android:gravity="center"
                      app:layout_constraintStart_toStartOf="parent"
                      app:layout_constraintEnd_toEndOf="parent"
                      app:layout_constraintTop_toBottomOf="@id/img_i_album_thumbnail">

            <ImageView android:layout_width="20dp"
                       android:layout_height="20dp"
                       app:url="@{profileImageUrl}"
                       app:radius="@{100}"/>

            <TextView android:layout_width="0dp"
                      android:layout_height="wrap_content"
                      android:layout_weight="1"
                      android:layout_marginStart="4dp"
                      android:maxLines="1"
                      android:ellipsize="end"
                      android:textAppearance="@style/Body_12_M"
                      android:textColor="@color/label_normal"
                      android:text="@{username}"
                      tools:text="purifree"/>

            <TextView android:layout_width="wrap_content"
                      android:layout_height="wrap_content"
                      android:textAppearance="@style/Body_12_M"
                      android:textColor="@color/label_normal"
                      android:text="@{numericalText}"
                      tools:text="조회수 9.1만 · 스크랩 1.2천"/>

        </LinearLayout>

        <TextView android:layout_width="0dp"
                  android:layout_height="wrap_content"
                  android:id="@+id/txt_i_album_row_2"
                  android:textAppearance="@style/Title_16"
                  android:textColor="@color/label_normal"
                  android:text="@{title}"
                  tools:text="제주도 여행기: 섬 속의 천국"
                  android:maxLines="2"
                  android:ellipsize="end"
                  android:paddingHorizontal="20dp"
                  android:layout_marginTop="4dp"
                  app:layout_constraintTop_toBottomOf="@id/ll_i_album_row_1"
                  app:layout_constraintStart_toStartOf="@id/ll_i_album_row_1"
                  app:layout_constraintEnd_toEndOf="@id/ll_i_album_row_1"/>

        <HorizontalScrollView android:id="@+id/hs_i_album_tags"
                              android:layout_width="0dp"
                              android:layout_height="wrap_content"
                              android:clipToPadding="false"
                              android:paddingHorizontal="20dp"
                              android:paddingVertical="10dp"
                              android:scrollbars="none"
                              app:layout_constraintStart_toStartOf="parent"
                              app:layout_constraintEnd_toEndOf="parent"
                              app:layout_constraintTop_toBottomOf="@id/txt_i_album_row_2">

            <LinearLayout android:layout_width="wrap_content"
                          android:layout_height="wrap_content"
                          android:id="@+id/ll_i_album_tags"
                          android:gravity="center"
                          android:orientation="horizontal"
                          android:minHeight="24dp" />

        </HorizontalScrollView>

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>
