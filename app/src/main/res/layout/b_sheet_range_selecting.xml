<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>

        <import type="com.tenacy.roadcapture.ui.ViewRange" />
    </data>

    <LinearLayout android:id="@+id/ll_b_sheet_range_selecting_container"
                  android:layout_width="match_parent"
                  android:layout_height="wrap_content"
                  android:orientation="vertical"
                  android:gravity="center"
                  app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior">

        <androidx.cardview.widget.CardView android:layout_width="48dp"
                                           android:layout_height="4dp"
                                           android:id="@+id/card_b_sheet_range_selecting_handle"
                                           app:cardElevation="0dp"
                                           app:cardCornerRadius="10dp"
                                           app:cardBackgroundColor="@color/fill_neutral"
                                           android:layout_marginTop="16dp"/>

        <TextView android:layout_width="wrap_content"
                  android:layout_height="wrap_content"
                  android:textAppearance="@style/Title_24"
                  android:textColor="@color/label_normal"
                  android:text="범위 선택"
                  android:layout_marginTop="20dp"/>

        <TextView android:layout_width="wrap_content"
                  android:layout_height="wrap_content"
                  android:textAppearance="@style/Body_12_M"
                  android:textColor="@color/label_neutral"
                  android:textAlignment="center"
                  android:text="이 근처에 여러 추억이 존재해요\n확인하고자 하는 범위를 선택해주세요"
                  android:layout_marginTop="4dp"/>

        <ImageView android:layout_width="168dp"
                   android:layout_height="168dp"
                   android:src="@drawable/scope"/>

        <com.google.android.material.chip.ChipGroup android:layout_width="match_parent"
                                                    android:layout_height="wrap_content"
                                                    android:id="@+id/cg_b_sheet_range_selecting"
                                                    android:paddingHorizontal="20dp"
                                                    app:chipSpacingHorizontal="4dp"
                                                    app:singleSelection="true"
                                                    app:selectionRequired="true"
                                                    app:checkedChip="@id/chip_b_sheet_range_selecting_around">

            <com.google.android.material.chip.Chip android:layout_width="match_parent"
                                                   android:layout_height="wrap_content"
                                                   android:id="@+id/chip_b_sheet_range_selecting_around"
                                                   style="@style/Chip.Choice.Range"
                                                   android:text="이 근처만"/>

            <com.google.android.material.chip.Chip android:layout_width="match_parent"
                                                   android:layout_height="wrap_content"
                                                   android:id="@+id/chip_b_sheet_range_selecting_whole"
                                                   style="@style/Chip.Choice.Range"
                                                   android:text="전체"/>

        </com.google.android.material.chip.ChipGroup>


        <Button android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:id="@+id/btn_b_sheet_range_selecting_positive"
                style="@style/Button"
                android:textAppearance="@style/Body_16_SB"
                android:textColor="@color/label_normal"
                android:text="확인하기"
                android:backgroundTint="@color/primary"
                app:cornerRadius="12dp"
                android:padding="12dp"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="20dp"
                android:layout_marginHorizontal="20dp"/>

    </LinearLayout>
</layout>
