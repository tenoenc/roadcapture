<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        xmlns:tools="http://schemas.android.com/tools">

    <data>
        <variable
                name="vm"
                type="com.tenacy.roadcapture.ui.CameraViewModel" />
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/black">

        <!-- 카메라 프리뷰 -->
        <androidx.camera.view.PreviewView
                android:id="@+id/preview_view"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

        <!-- 카메라 컨트롤 레이아웃 -->
        <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/camera_controls_layout"
                android:layout_width="match_parent"
                android:layout_height="match_parent">

            <!-- 상단 툴바 -->
            <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/camera_top_controls"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#80000000"
                    android:padding="16dp"
                    app:layout_constraintTop_toTopOf="parent">

                <ImageButton
                        android:id="@+id/btn_back"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:padding="4dp"
                        android:scaleType="fitCenter"
                        android:src="@drawable/ic_arrow_left"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:tint="@color/background_normal" />

                <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="사진 촬영"
                        android:textColor="@color/background_normal"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        app:layout_constraintBottom_toBottomOf="@id/btn_back"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="@id/btn_back" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- 하단 컨트롤 -->
            <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/camera_bottom_controls"
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:background="#80000000"
                    app:layout_constraintBottom_toBottomOf="parent">

                <com.google.android.material.floatingactionbutton.FloatingActionButton
                        android:id="@+id/btn_capture"
                        android:layout_width="72dp"
                        android:layout_height="72dp"
                        android:layout_marginBottom="24dp"
                        app:backgroundTint="@color/background_normal"
                        app:fabCustomSize="72dp"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:maxImageSize="36dp"
                        app:shapeAppearance="@style/ShapeAppearance.App.LargeComponent"
                        app:srcCompat="@drawable/ic_camera"
                        app:tint="@color/black" />

            </androidx.constraintlayout.widget.ConstraintLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- 사진 미리보기 레이아웃 (처음에는 숨김) -->
        <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/capture_preview_layout"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="gone"
                tools:visibility="visible">

            <!-- 미리보기 이미지 -->
            <ImageView
                    android:id="@+id/image_preview"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="fitCenter" />

            <!-- 상단 툴바 -->
            <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/preview_top_controls"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#80000000"
                    android:padding="16dp"
                    app:layout_constraintTop_toTopOf="parent">

                <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="미리보기"
                        android:textColor="@color/background_normal"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- 하단 컨트롤 -->
            <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/preview_bottom_controls"
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:background="#80000000"
                    app:layout_constraintBottom_toBottomOf="parent">

                <Button
                        android:id="@+id/btn_retake_photo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="32dp"
                        android:backgroundTint="@color/fill_alternative"
                        android:text="다시 찍기"
                        android:textColor="@color/label_normal"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                <Button
                        android:id="@+id/btn_use_photo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="32dp"
                        android:backgroundTint="@color/primary"
                        android:text="사용하기"
                        android:textColor="@color/background_normal"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>